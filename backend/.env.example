# YOLO 모델 가중치 경로 (models/ 폴더 기준)
MODEL_PATH=models/yolov8n.pt

# CORS 허용 오리진 (쉼표로 구분)
ALLOWED_ORIGINS_RAW=http://localhost:3000

# 혼잡도 판단 기준 인원 수
CONGESTION_THRESHOLD=5

# 이벤트 이미지 저장 최소 간격 (초)
EVENT_SAVE_INTERVAL_SECONDS=5

# 혼잡 알림음 재생 최소 간격 (초)
EVENT_SOUND_INTERVAL_SECONDS=3

# 프레임 JPEG 품질 (1~100)
FRAME_JPEG_QUALITY=85

# 스트리밍 목표 해상도
STREAM_TARGET_WIDTH=854
STREAM_TARGET_HEIGHT=480

# YouTube 보호 스트림 쿠키 파일 경로 (필요한 경우만)
# YOUTUBE_COOKIE_FILE=config/cookies.txt

# 관리자 이벤트 삭제 API 시크릿 키
CLEANUP_SECRET=changeme
